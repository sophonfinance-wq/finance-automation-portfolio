{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: debug current test file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q", "${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONPATH": "${workspaceFolder}/monthly-close-automation:${workspaceFolder}/cash-reconciliation:${workspaceFolder}/cash-management:${workspaceFolder}/tax-surplus-engine:${workspaceFolder}/partnership-1065-automation:${workspaceFolder}/audit-automation:${workspaceFolder}/ai-validation-framework:${workspaceFolder}/knowledge-brain-engine:${workspaceFolder}/finance-atlas"
      }
    },
    {
      "name": "Cash Management: debug demo",
      "type": "debugpy",
      "request": "launch",
      "module": "cash_engine",
      "args": ["--demo"],
      "cwd": "${workspaceFolder}/cash-management",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}

